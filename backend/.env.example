# Vortexa Server Configuration
PORT=5000
NODE_ENV=development

# Authentication Secrets (Replace with secure keys in production)
JWT_SECRET=vortexa_default_super_secret_key_change_me_in_prod
JWT_REFRESH_SECRET=vortexa_default_refresh_secret_key_change_me_in_prod

# Vault Database Path
DB_PATH=vortexa.db

# Wallet Encryption Key (Must be exactly 32 bytes for AES-256-CBC)
ENCRYPTION_KEY=vortexa_encryption_32_byte_key_!@#
