# Vortexa Server Configuration
PORT=5000
NODE_ENV=development

# Authentication Secrets (64-character / 32-byte secure hex keys)
JWT_SECRET=your_jwt_secret_hex_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_hex_key_here

# MongoDB Connection URI
MONGO_URI=mongodb://127.0.0.1:27017/vortexa

# Wallet Encryption Key (Must be exactly 32 characters/bytes for AES-256-CBC)
ENCRYPTION_KEY=your_32_character_encryption_key_here
